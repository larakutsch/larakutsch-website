---
import Layout from '../components/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Marquee from '../components/Marquee.astro';

const today = new Date().toLocaleDateString('de-DE', { day: '2-digit', month: 'long', year: 'numeric' }).toUpperCase();
const todayEN = new Date().toLocaleDateString('en-GB', { day: '2-digit', month: 'long', year: 'numeric' }).toUpperCase();

const marqueeItems = ['Cosmopolitan','Handelsblatt','Seaside Magazin','Brautmagazin','WELT Lifestyle','Marie Claire'];
---
<Layout>
  <Header active="home" />

  <main>
    <!-- HERO -->
    <section class="hero">
      <div class="hero-bar">
        <span class="kicker ink">
          <span data-lang="de">Hamburg &amp; Überall</span>
          <span data-lang="en">Hamburg &amp; Everywhere</span>
        </span>
        <span class="kicker ink">
          <span data-lang="de">{today}</span>
          <span data-lang="en">{todayEN}</span>
        </span>
      </div>

      <div class="hero-grid">
        <div class="hero-video-wrap">
          <div class="orange-bg"></div>
          <video autoplay loop muted playsinline class="hero-video">
            <source src="/hero.mp4" type="video/mp4" />
          </video>
        </div>
        <div class="hero-text">
          <div class="hero-name">Lara<br/>Kutsch</div>
          <div class="hero-role">
            <span data-lang="de">Freie Journalistin</span>
            <span data-lang="en">Freelance Journalist</span>
          </div>
          <a href="/contact" class="cta" data-cursor="mail" data-cursor-label="MAIL">
            <span data-lang="de">Anfrage senden →</span>
            <span data-lang="en">Send a request →</span>
          </a>

          <div class="offer">
            <h2 class="offer-title">
              <span data-lang="de">Was ich anbiete:</span>
              <span data-lang="en">What I offer:</span>
            </h2>
            <ul class="offer-list">
              <li>
                <span data-lang="de">Artikel, Reportagen, Interviews für Print und Digital</span>
                <span data-lang="en">Articles, features, interviews for print and digital</span>
              </li>
              <li>
                <span data-lang="de">Redaktionelle Leitung und Textchef-Aufgaben</span>
                <span data-lang="en">Editorial management and copy-editing</span>
              </li>
              <li>
                <span data-lang="de">SEO-Strategien und -Optimierungen</span>
                <span data-lang="en">SEO strategy and optimisation</span>
              </li>
              <li>
                <span data-lang="de">Social Media Content</span>
                <span data-lang="en">Social media content</span>
              </li>
              <li>
                <span data-lang="de">Texte für Unternehmen und Marken</span>
                <span data-lang="en">Copywriting for companies and brands</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <Marquee items={marqueeItems} />
  </main>

  <Footer />
</Layout>

<style>
  .hero { padding: 24px 40px 80px; }
  .hero-bar {
    display: flex; justify-content: space-between; align-items: baseline;
    border-bottom: 1px solid var(--ink); padding-bottom: 12px; margin-bottom: 24px;
  }
  .kicker {
    font-family: var(--font-ui); font-size: 11px; letter-spacing: 0.16em;
    text-transform: uppercase; font-weight: 600;
  }
  .kicker.ink   { color: var(--ink); }
  .kicker.muted { color: var(--fg-2); }

  .hero-grid {
    display: grid; grid-template-columns: minmax(0,1.1fr) minmax(0,1fr);
    gap: 48px; align-items: start; margin-top: 24px; position: relative; z-index: 2;
  }
  .hero-video-wrap { position: relative; padding: 40px 28px 48px 24px; }
  .orange-bg {
    position: absolute; inset: 14px 28px 24px -8px;
    background: #EE6A1F; transform: rotate(-2.4deg);
    box-shadow: 0 1px 0 var(--hairline);
  }
  .hero-video {
    display: block; width: 100%; aspect-ratio: 4/5; max-width: 520px;
    object-fit: cover; transform: rotate(0.5deg);
    box-shadow: 0 24px 60px -20px rgba(10,10,10,0.35); position: relative;
  }
  .hero-text { padding-top: 24px; }
  .hero-name {
    font-family: var(--font-display); font-size: clamp(4.5rem, 9vw, 12rem);
    font-weight: 700; letter-spacing: -0.04em; line-height: 0.88;
    color: #F2D72A; margin-bottom: 16px;
  }
  .hero-role {
    font-family: var(--font-display); font-size: clamp(1.25rem, 2vw, 2rem);
    font-weight: 700; letter-spacing: -0.02em; line-height: 1.1;
    color: var(--ink); margin-bottom: 12px;
  }
  .hero-sub {
    font-family: var(--font-body); font-size: clamp(1rem, 1.3vw, 1.25rem);
    line-height: 1.45; margin: 0 0 32px; color: var(--fg-2); max-width: 42ch;
  }
  .cta {
    font-family: var(--font-ui); font-size: 12px; letter-spacing: 0.16em;
    text-transform: uppercase; color: var(--accent-ink); background: var(--accent);
    text-decoration: none; padding: 10px 18px; font-weight: 700; display: inline-block;
  }

  .offer { margin-top: 40px; }
  .offer-title {
    font-family: var(--font-ui); font-size: 12px; letter-spacing: 0.16em;
    text-transform: uppercase; font-weight: 700; color: var(--ink);
    margin: 0 0 16px;
  }
  .offer-list {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 10px;
  }
  .offer-list li {
    font-family: var(--font-body); font-size: 17px; line-height: 1.4;
    color: var(--fg-1); padding-left: 20px; position: relative;
  }
  .offer-list li::before {
    content: "•"; position: absolute; left: 0; color: var(--accent);
  }

  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr; row-gap: 0; }
    /* dissolve .hero-text so its children can be reordered individually,
       independent of .offer, without duplicating markup */
    .hero-text      { display: contents; }
    .hero-name      { order: 1; margin-top: 24px; }
    .hero-role      { order: 2; }
    .cta            { order: 3; }
    .hero-video-wrap { order: 4; margin-top: 48px; }
    .offer          { order: 5; margin-top: 32px; }
  }
  @media (max-width: 600px) {
    .hero { padding-left: 20px; padding-right: 20px; }
  }
</style>
