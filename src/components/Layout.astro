---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

// ── Wartungsmodus ─────────────────────────────────────────────────────────────
// Auf false setzen und pushen, um zur normalen Website zurückzukehren.
const MAINTENANCE_MODE = false;
// ─────────────────────────────────────────────────────────────────────────────

const {
  title = 'Lara Kutsch — Freie Journalistin',
  description = 'Freie Journalistin aus Hamburg. Mode, Lifestyle, Reisen, Zeitgeist.',
} = Astro.props;
---
<!doctype html>
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <title>{MAINTENANCE_MODE ? 'Lara Kutsch — Bald zurück' : title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>

{MAINTENANCE_MODE ? (
  <div class="m-wrap">
    <p class="m-label">Lara Kutsch · Freie Journalistin</p>
    <h1 class="m-title">Bald zurück.</h1>
    <p class="m-text">
      Ich arbeite derzeit an meiner Website<br />
      und bin demnächst für dich da.
    </p>
  </div>
) : (
  <Fragment>
    <div id="cursor"><span id="cursor-label"></span></div>
    <slot />
  </Fragment>
)}

{!MAINTENANCE_MODE && (
  <script>
    // Custom cursor
    const cursor = document.getElementById('cursor');
    const cursorLabel = document.getElementById('cursor-label');
    if (cursor && cursorLabel) {
      document.addEventListener('mousemove', (e) => {
        cursor.style.left = e.clientX + 'px';
        cursor.style.top  = e.clientY + 'px';
      });
      document.addEventListener('mouseover', (e) => {
        const t = (e.target as Element).closest('[data-cursor]');
        if (t) {
          const v = t.getAttribute('data-cursor');
          const label = t.getAttribute('data-cursor-label') || (v || '').toUpperCase();
          cursor.classList.add('is-big');
          cursorLabel.textContent = label;
        } else {
          cursor.classList.remove('is-big');
          cursorLabel.textContent = '';
        }
      });
    }

    // Language toggle
    const langBtn = document.getElementById('lang-btn');
    if (langBtn) {
      const DE = document.querySelectorAll('[data-lang="de"]');
      const EN = document.querySelectorAll('[data-lang="en"]');
      let lang = localStorage.getItem('lang') || 'de';

      function applyLang() {
        DE.forEach(el => (el as HTMLElement).hidden = lang !== 'de');
        EN.forEach(el => (el as HTMLElement).hidden = lang !== 'en');
        langBtn!.textContent = lang === 'de' ? 'EN' : 'DE';
      }
      applyLang();

      langBtn.addEventListener('click', () => {
        lang = lang === 'de' ? 'en' : 'de';
        localStorage.setItem('lang', lang);
        applyLang();
      });
    }

    // Sticky header
    const header = document.querySelector('header');
    if (header) {
      window.addEventListener('scroll', () => {
        header.classList.toggle('scrolled', window.scrollY > 40);
      });
    }
  </script>
)}

</body>
</html>

<style>
  /* ── Wartungsseite ─────────────────────────────── */
  .m-wrap {
    min-height: 100svh;
    display: flex; flex-direction: column;
    justify-content: center;
    padding: 48px 40px;
    max-width: 780px;
    margin: 0 auto;
  }
  .m-label {
    font-family: var(--font-ui); font-size: 11px;
    letter-spacing: 0.18em; text-transform: uppercase;
    font-weight: 600; color: var(--fg-2);
    margin: 0 0 40px;
  }
  .m-title {
    font-family: var(--font-display);
    font-size: clamp(4rem, 12vw, 10rem);
    font-weight: 700; letter-spacing: -0.04em; line-height: 0.9;
    margin: 0 0 40px; color: var(--ink);
  }
  .m-text {
    font-family: var(--font-body); font-size: clamp(1.1rem, 2vw, 1.375rem);
    line-height: 1.6; color: var(--fg-2);
    max-width: 40ch; margin: 0;
  }

  /* ── Cursor (Normalseite) ──────────────────────── */
  #cursor {
    position: fixed; pointer-events: none; z-index: 9999;
    width: 18px; height: 18px; border-radius: 999px;
    background: #EE6A1F; color: #fff;
    transform: translate(-50%, -50%);
    transition: width 240ms var(--ease-spring), height 240ms var(--ease-spring);
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-ui); font-size: 11px;
    letter-spacing: 0.12em; text-transform: uppercase; font-weight: 700;
  }
  #cursor.is-big { width: 80px; height: 80px; }
  @media (max-width: 720px), (hover: none) { #cursor { display: none; } }
</style>
