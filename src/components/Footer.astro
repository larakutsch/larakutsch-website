<footer>
  <div class="grid">
    <div>
      <div class="name">Lara<br/>Kutsch</div>
      <div class="sub">Freie Journalistin · Hamburg</div>
    </div>
    <div>
      <div class="col-head">Kontakt</div>
      <a href="mailto:hallo@larakutsch.de" class="foot-link">hallo@larakutsch.de</a>
      <div class="foot-text">+49 15 – auf Anfrage</div>
    </div>
    <div>
      <div class="col-head">
        <span data-lang="de">Folgen</span>
        <span data-lang="en">Follow</span>
      </div>
      <a href="https://www.instagram.com/lara_kutsch/" target="_blank" rel="noopener" class="foot-link">Instagram ↗</a>
      <a href="https://www.linkedin.com/in/lara-kutsch-93151a1b9/" target="_blank" rel="noopener" class="foot-link">LinkedIn ↗</a>
      <a href="https://substack.com/@larakutsch" target="_blank" rel="noopener" class="foot-link">Substack ↗</a>
    </div>
    <div>
      <div class="col-head">
        <span data-lang="de">Schwerpunkte</span>
        <span data-lang="en">Beats</span>
      </div>
      <div class="foot-text">Mode<br/>Lifestyle<br/>Zeitgeist</div>
    </div>
  </div>
  <div class="bottom">
    <span>© 2026 Lara Kutsch</span>
    <span>Impressum · Datenschutz</span>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--ink);
    padding: 48px 40px 32px;
    margin-top: 96px;
    background: var(--ink);
    color: var(--paper);
  }
  .grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 48px; align-items: start;
  }
  .name {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 700; letter-spacing: -0.03em; line-height: 0.92;
  }
  .sub {
    font-family: var(--font-ui); font-size: 12px;
    letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--smoke-2); margin-top: 18px;
  }
  .col-head {
    font-family: var(--font-ui); font-size: 11px;
    letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--smoke-2); margin-bottom: 14px;
  }
  .foot-link {
    display: block; color: var(--paper);
    text-decoration: none; font-size: 15px; margin-bottom: 8px;
  }
  .foot-text { color: var(--paper); font-size: 15px; line-height: 1.6; }
  .bottom {
    border-top: 1px solid rgba(246,243,238,0.16);
    margin-top: 48px; padding-top: 18px;
    display: flex; justify-content: space-between;
    font-family: var(--font-ui); font-size: 11px;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--smoke-2);
  }
  @media (max-width: 720px) {
    .grid { grid-template-columns: 1fr 1fr; gap: 32px; }
  }
</style>
